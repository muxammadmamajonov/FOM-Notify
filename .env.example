# Telegram bot credentials (required for normal run)
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
GROUP_CHAT_ID=

# Dashboard source — the Apps Script /exec URL
TARGET_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Optional: override the "open dashboard" button URL (defaults to TARGET_URL)
WEB_APP_URL=

# IANA timezone used for the cron schedule and report captions
TZ=Asia/Tashkent

# SQLite path for the subscribers table (kept for future use; not required for
# daily delivery to GROUP_CHAT_ID). Relative paths resolve against the project
# root.
DB_PATH=data/subscribers.db

# Set to 1 to run a single capture and exit (no bot needed).
RUN_ONCE=0

# Set HEADLESS=0 to run Chromium in headful mode for debugging. Default 1.
HEADLESS=1

# Apps Script auto-deploy (optional). Requires Node.js + `clasp` on the host
# and a logged-in ~/.clasprc.json. Leave APPS_SCRIPT_AUTO_UPDATE=0 if you
# don't use it — the scheduler will skip cleanly.
APPS_SCRIPT_AUTO_UPDATE=0
CLASP_WORKDIR=.
CLASP_DEPLOYMENT_ID=
