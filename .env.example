# Telegram bot credentials (required)
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=
GROUP_CHAT_ID=

# Dashboard source — the Apps Script /exec URL
TARGET_URL=https://script.google.com/macros/s/REPLACE_ME/exec

# Optional: override the "open dashboard" button URL (defaults to TARGET_URL)
WEB_APP_URL=

# IANA timezone for the cron schedule and report captions
TZ=Asia/Tashkent

# SQLite path for the subscribers table (legacy; not required for daily delivery
# to GROUP_CHAT_ID). Relative paths resolve against the project root.
DB_PATH=data/subscribers.db

# Set to 1 to run a single capture and exit (no bot needed; for smoke testing).
RUN_ONCE=0

# ---------------------------------------------------------------------------
# ScreenshotOne API — replaces Playwright/Chromium.
# Free tier = 100 screenshots/month per account. Configure up to 4 accounts;
# the bot falls over to the next one on quota exhaustion (HTTP 402/429) or
# any transient error. Account #1 is required; #2-#4 are optional.
#
# Sign up at https://screenshotone.com  → grab Access key + Secret key.
# ---------------------------------------------------------------------------
SCREENSHOTONE_ACCESS_KEY=
SCREENSHOTONE_SECRET_KEY=
SCREENSHOTONE_ACCESS_KEY_2=
SCREENSHOTONE_SECRET_KEY_2=
SCREENSHOTONE_ACCESS_KEY_3=
SCREENSHOTONE_SECRET_KEY_3=
SCREENSHOTONE_ACCESS_KEY_4=
SCREENSHOTONE_SECRET_KEY_4=

# Apps Script auto-deploy (optional). Requires Node.js + `clasp` on the host
# and a logged-in ~/.clasprc.json. Leave APPS_SCRIPT_AUTO_UPDATE=0 if you
# don't use it — the scheduler will skip cleanly.
APPS_SCRIPT_AUTO_UPDATE=0
CLASP_WORKDIR=.
CLASP_DEPLOYMENT_ID=
